{
  "expo": {
    "name": "UltraLite",
    "slug": "ultralite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f7f5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.ultralite.ios"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f8f7f5"
      },
      "package": "app.ultralite.android"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "scheme": "ultralite",
    "experiments": {
      "typedRoutes": false
    }
  }
}
